{
  "name": "@motif/design",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "description": "Motif design library — tokens and atoms for externally-facing SvelteKit projects",
  "files": [
    "dist",
    "src/tokens"
  ],
  "exports": {
    ".": {
      "import": "./dist/design.js",
      "types": "./dist/index.d.ts",
      "svelte": "./src/index.ts"
    },
    "./public": "./src/tokens/public.css",
    "./admin": "./src/tokens/admin.css",
    "./base": "./src/tokens/base.css",
    "./form-states": "./src/tokens/form-states.css"
  },
  "scripts": {
    "dev": "echo 'dev script — to be configured in task 002'",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/azeret-mono": "^5.2.11",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.0.0",
    "@fontsource/rock-salt": "^5.0.0",
    "gsap": "^3.14.2"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "devDependencies": {
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/svelte-vite": "^10.3.5",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "storybook": "^10.3.5",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  }
}
